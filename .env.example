# =================================================================
# EresumeHub - Frontend Environment Template (Vite)
# =================================================================

# --- 🕋 SUPABASE (Required) ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# --- 🚀 BACKEND SYNC (Required) ---
# The URL of your Render backend (exclude /api/v1)
VITE_API_URL="https://eresumehub-backend.onrender.com"

# The same key configured in your backend's API_SECRET_KEY
VITE_API_KEY="staff-level-secret-replace-in-production-immediately"

# --- ⚙️ CONFIGURATION ---
# Optional: Set to 'production' or 'development'
VITE_ENV_NAME="development"
